#include<iostream>
using namespace std;
class Vehicle {
public:
	Vehicle() {
		cout << "A vehicle is creating now.\n";
	}
	void calcFuelConsumption() {

	}
	~Vehicle() {
		cout << "The vehicle is devastating now.\n";
	}
};
class Car : public Vehicle {
private:
	double oil_capacity;
	double consumption_per_100km;
public:
	void calcFuelConsumption(double km)const {
		double ans = km * consumption_per_100km / 100;
		if (ans > oil_capacity) {
			cout << "Wrong,your car can't run this way far!" << endl;
			return;
		}
		else {
			cout << "You will consume:" << ans << "\n";
			return;
		}
	}
	Car(double oil,double consumption) {
		cout << "I am a car!" << endl;
		oil_capacity = oil;
		consumption_per_100km = consumption;
	}
	~Car() {
		cout << "A car is dying away" << endl;
	}
};
class Ship :public Vehicle {
